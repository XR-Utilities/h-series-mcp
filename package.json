{
  "name": "@xr-utilities/h-series-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for the H-Series product family: H-Index (capability registry), H-Seal (receipt anchoring), H-Grant (credential release), H-Relay (agent transport), H-Scope (wallet scanning), H-Pact (membership rings), and H-Gate (data-egress control). Stateless passthrough. Caller provides x402 payment header.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "h-series-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test dist/",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js --transport stdio",
    "start:http": "node dist/index.js --transport http",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "startup": "bash scripts/startup.sh",
    "closeout": "bash scripts/closeout.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "hedera",
    "hcs",
    "x402",
    "agents",
    "h-index",
    "h-seal",
    "receipts",
    "registry"
  ],
  "homepage": "https://h-seal.xr-utilities.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/XR-Utilities/h-series-mcp.git"
  }
}
