# h-series-mcp environment. All vars are optional: the server is a stateless
# passthrough with working defaults. Copy to .env for local overrides. No
# secrets live here; the caller supplies any x402 payment envelope per call.

# Transport selection when not passed on the CLI: "stdio" (default) or "http".
MCP_TRANSPORT=stdio

# HTTP transport listen port. Defaults to 8080. Only read for the http transport.
PORT=8080

# Log threshold for the structured stderr logger: debug | info | warn | error.
# Defaults to info.
LOG_LEVEL=info

# Set to 1 to skip the startup schema-discipline check (the live backend
# config/manifest fetch). Useful when dev networking is flaky. Default: run it.
MCP_SKIP_VALIDATE=0

# Set to 1 to exit non-zero when the startup check finds schema drift against a
# backend. Default: log and continue.
MCP_FAIL_ON_DRIFT=0

# Backend base URL overrides. Each backend defaults to its live production host;
# set these to point the proxy at a staging or local instance. Only H-Seal and
# H-Relay are overridable today; the other six backends use hardcoded prod hosts.
H_SEAL_BACKEND_URL=https://h-seal.xr-utilities.ai
H_RELAY_BACKEND_URL=https://h-relay-production.up.railway.app
